{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "noResolve": false
  },
  "exclude": [
    "src/**/*.spec.ts",
    "src/test-setup.ts",
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.stories.ts",
    "src/integration-tests/**/*",
    "**/*.md",
    "src/**/*.md"
  ],
  "include": ["src/**/*.ts"]
}
