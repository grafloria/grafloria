{
  "name": "react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/react/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/react",
        "main": "libs/react/src/index.ts",
        "tsConfig": "libs/react/tsconfig.lib.json",
        "assets": [
          "libs/react/*.md"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/react/jest.config.ts"
      }
    },
    "build-esm": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "{workspaceRoot}/dist/libs/react/esm"
      ],
      "options": {
        "command": "npx tsc -p libs/react/tsconfig.esm.json --module es2022 --moduleResolution bundler --outDir dist/libs/react/esm --rootDir libs/react --declaration false --declarationMap false --incremental false"
      }
    }
  }
}
