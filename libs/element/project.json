{
  "name": "element",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/element/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/element",
        "main": "libs/element/src/index.ts",
        "tsConfig": "libs/element/tsconfig.lib.json",
        "assets": [
          "libs/element/README.md"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/element/jest.config.ts"
      }
    },
    "build-esm": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "{workspaceRoot}/dist/libs/element/esm"
      ],
      "options": {
        "command": "npx tsc -p libs/element/tsconfig.esm.json --module es2022 --moduleResolution bundler --outDir dist/libs/element/esm --rootDir libs/element --declaration false --declarationMap false --incremental false"
      }
    }
  }
}
