{
  "name": "engine",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/engine/src",
  "projectType": "library",
  "release": {
    "version": {
      "generatorOptions": {
        "packageRoot": "dist/{projectRoot}",
        "currentVersionResolver": "git-tag",
        "fallbackCurrentVersionResolver": "disk"
      }
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/engine",
        "main": "libs/engine/src/index.ts",
        "tsConfig": "libs/engine/tsconfig.lib.json",
        "assets": [
          "libs/engine/README.md"
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/engine/jest.config.ts"
      }
    },
    "build-esm": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "{workspaceRoot}/dist/libs/engine/esm"
      ],
      "options": {
        "command": "npx tsc -p libs/engine/tsconfig.lib.json --module es2022 --moduleResolution bundler --outDir dist/libs/engine/esm --rootDir libs/engine --declaration false --declarationMap false --incremental false"
      }
    }
  }
}
