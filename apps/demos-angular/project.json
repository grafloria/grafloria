{
  "name": "demos-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/demos-angular/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/demos-angular",
        "index": "apps/demos-angular/src/index.html",
        "browser": "apps/demos-angular/src/main.ts",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/demos-angular/tsconfig.app.json",
        "styles": [
          "apps/demos-angular/src/styles.css"
        ],
        "baseHref": "./",
        "outputHashing": "none",
        "optimization": true,
        "budgets": [
          {
            "type": "initial",
            "maximumWarning": "3mb",
            "maximumError": "6mb"
          }
        ]
      },
      "configurations": {
        "production": {}
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "buildTarget": "demos-angular:build",
        "port": 4310
      }
    }
  }
}